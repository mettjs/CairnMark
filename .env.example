# CairnMark configuration (12-factor env vars). Copy to .env for local use.
# All variables have safe defaults; none are required to boot in Phase 0.

# --- HTTP server ---
CAIRNMARK_HTTP_ADDR=:8080            # listen address (default :8080)
CAIRNMARK_SHUTDOWN_TIMEOUT=10s       # graceful shutdown grace period (default 10s)
CAIRNMARK_PRESIGN_TTL=15m            # lifetime of presigned download URLs (default 15m)

# --- Garbage collection (reconciliation sweep) ---
# NOTE: the sweep also expires idempotency keys, so disabling GC (<=0) lets the
# idempotency_keys table grow unbounded, in addition to leaving orphans and
# soft-deleted objects unreclaimed. Keep GC enabled in production.
CAIRNMARK_GC_INTERVAL=5m             # sweep cadence; <=0 disables GC (default 5m)
CAIRNMARK_GC_GRACE_PERIOD=1h         # min age before an unreferenced object is
                                     # reclaimed as an orphan; must exceed the
                                     # longest plausible upload (default 1h)
CAIRNMARK_IDEMPOTENCY_TTL=24h        # how long upload idempotency keys are kept
                                     # before the sweep expires them; <=0 disables
                                     # expiry (default 24h)

# --- Postgres metadata (wired in Phase 1) ---
# Matches the docker-compose Postgres service.
CAIRNMARK_POSTGRES_DSN=postgres://cairnmark:cairnmark@localhost:5432/cairnmark?sslmode=disable

# --- S3-compatible storage (wired in Phase 1) ---
# Matches the docker-compose MinIO service.
CAIRNMARK_S3_ENDPOINT=localhost:9000   # host:port for service-side I/O, no scheme
CAIRNMARK_S3_REGION=us-east-1
CAIRNMARK_S3_ACCESS_KEY=cairnmark
CAIRNMARK_S3_SECRET_KEY=cairnmark-secret
CAIRNMARK_S3_BUCKET=cairnmark
CAIRNMARK_S3_USE_SSL=false

# Public endpoint baked into presigned download URLs. Leave unset to reuse
# CAIRNMARK_S3_ENDPOINT. Set this when the service reaches the store by an
# internal name (e.g. minio:9000 inside Compose) but external clients use a
# different public host. The host is part of the URL signature, so it is signed
# directly against this value — it cannot be rewritten after signing.
#CAIRNMARK_S3_PUBLIC_ENDPOINT=files.example.com
#CAIRNMARK_S3_PUBLIC_USE_SSL=true       # defaults to CAIRNMARK_S3_USE_SSL
